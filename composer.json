{
    "name": "gordon-fcl/housekeeping",
    "description": "A Laravel package to view and manage GitHub issues from the terminal.",
    "keywords": [
        "php",
        "laravel",
        "github",
        "housekeeping",
        "issues"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Gordon Thomson",
            "email": "gordonthomson@protonmail.com"
        }
    ],
    "require": {
        "php": "^8.2.0",
        "graham-campbell/github": "^12.6|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "laravel/prompts": "^0.1.16|^0.2|^0.3"
    },
    "require-dev": {
        "dg/bypass-finals": "^1.8",
        "laravel/pint": "^1.13.7",
        "orchestra/testbench": "^8.0|^9.0",
        "pestphp/pest": "^2.28.1",
        "phpstan/phpstan": "^2.0",
        "rector/rector": "^2.0",
        "symfony/var-dumper": "^6.4.0|^7.0.0"
    },
    "autoload": {
        "psr-4": {
            "FCL\\Housekeeping\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "scripts": {
        "refacto": "rector",
        "lint": "pint",
        "test:refacto": "rector --dry-run",
        "test:lint": "pint --test",
        "test:types": "phpstan analyse --ansi",
        "test:unit": "pest --colors=always",
        "test": [
            "@test:refacto",
            "@test:lint",
            "@test:types",
            "@test:unit"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "FCL\\Housekeeping\\Providers\\PackageServiceProvider"
            ]
        }
    }
}
